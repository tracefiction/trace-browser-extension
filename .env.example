# Copy to .env and adjust. Used by `npm run build` to inject URLs into background.js.

# API origin (no trailing slash). Default: local Trace server.
TRACE_API_BASE=http://localhost:3001

# Trace web app origin (no trailing slash). Used for /import links and /apps help link.
# Default: Vite dev. For https dev/staging, the build adds that origin to manifest
# (host_permissions + sync.js) so token sync works on the deployed app.
# Also written to iOS (App)/TraceWebOrigin.generated.swift — DEBUG WKWebView loads this origin.
TRACE_WEB_ORIGIN=http://localhost:5173

# Production example:
# TRACE_API_BASE=https://tracefiction.com
# TRACE_WEB_ORIGIN=https://tracefiction.com

# Deployed dev (Safari on device — rebuild extension after changing):
# TRACE_API_BASE=https://api.example.dev
# TRACE_WEB_ORIGIN=https://app.example.dev
